<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_sms_basic_user" model="res.groups">
        <field name="name">Basic User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Can send adhoc SMS only</field>
    </record>
    
    <record id="group_sms_department_admin" model="res.groups">
        <field name="name">Department Admin</field>
        <field name="implied_ids" eval="[(4, ref('group_sms_basic_user'))]"/>
        <field name="comment">Can send mass SMS to own department staff</field>
    </record>
    
    <record id="group_sms_faculty_admin" model="res.groups">
        <field name="name">Faculty Admin</field>
        <field name="implied_ids" eval="[(4, ref('group_sms_department_admin'))]"/>
        <field name="comment">Can send to students across multiple departments</field>
    </record>
    
    <record id="group_sms_administrator" model="res.groups">
        <field name="name">SMS Administrator</field>
        <field name="implied_ids" eval="[(4, ref('group_sms_faculty_admin'))]"/>
        <field name="comment">Full SMS access except provider config</field>
    </record>
    
    <record id="group_sms_system_admin" model="res.groups">
        <field name="name">System Admin</field>
        <field name="implied_ids" eval="[(4, ref('group_sms_administrator'))]"/>
        <field name="comment">Full Configuration Access</field>
        </record>

    </odoo>