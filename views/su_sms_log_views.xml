<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list View -->
    <record id="view_su_sms_log_list" model="ir.ui.view">
        <field name="name">su.sms.log.list</field>
        <field name="model">su.sms.log</field>
        <field name="arch" type="xml">
            <list string="SMS Logs" default_order="create_date desc">
                <field name="create_date"/>
                <field name="number"/>
                <field name="department_id"/>
                <field name="sender_id"/>
                <field name="status" decoration-success="status == 'sent'" 
                       decoration-danger="status == 'failed'"/>
                <field name="cost"/>
                <field name="message_length"/>
                <field name="sms_count"/>
            </list>
        </field>
    </record>
    
    <!-- Form View -->
    <record id="view_su_sms_log_form" model="ir.ui.view">
        <field name="name">su.sms.log.form</field>
        <field name="model">su.sms.log</field>
        <field name="arch" type="xml">
            <form string="SMS Log">
                <sheet>
                    <group>
                        <group>
                            <field name="number"/>
                            <field name="department_id"/>
                            <field name="sender_id"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="cost"/>
                            <field name="sms_count"/>
                            <field name="provider_message_id"/>
                        </group>
                    </group>
                    <group string="Message">
                        <field name="message" nolabel="1"/>
                    </group>
                    <group string="Failure Details" attrs="{'invisible': [('status', 'not in', ['failed', 'bounced'])]}">
                        <field name="failure_reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Action -->
    <record id="action_su_sms_log" model="ir.actions.act_window">
        <field name="name">SMS Logs</field>
        <field name="res_model">su.sms.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>
    
    <!-- Menu Item -->
    <menuitem id="menu_su_sms_log"
              name="SMS Logs"
              parent="menu_sms_root"
              action="action_su_sms_log"
              sequence="30"/>
</odoo>