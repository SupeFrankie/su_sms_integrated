<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="su_sms_detail_view_pivot" model="ir.ui.view">
        <field name="name">su.sms.detail.pivot.billing</field>
        <field name="model">su.sms.detail</field>
        <field name="arch" type="xml">
            <pivot string="SMS Billing Report" sample="1">
                <field name="department_id" type="row"/>
                <field name="create_date"   type="col" interval="month"/>
                <field name="cost"          type="measure" string="Cost (KES)"/>
                <field name="recipient_count" type="measure" string="Recipients"/>
            </pivot>
        </field>
    </record>

    <record id="su_sms_detail_view_graph" model="ir.ui.view">
        <field name="name">su.sms.detail.graph.billing</field>
        <field name="model">su.sms.detail</field>
        <field name="arch" type="xml">
            <graph string="SMS Cost by Department" type="bar" sample="1">
                <field name="department_id" type="row"/>
                <field name="cost"          type="measure" string="Cost (KES)"/>
            </graph>
        </field>
    </record>

    <record id="su_sms_detail_view_list" model="ir.ui.view">
        <field name="name">su.sms.detail.list.billing</field>
        <field name="model">su.sms.detail</field>
        <field name="arch" type="xml">
            <list string="Recipient Details"
                  decoration-success="status == 'sent'"
                  decoration-danger="status == 'failed'"
                  decoration-warning="status == 'rejected'">
                <field name="create_date"    string="Date" optional="show"/>
                <field name="department_id"  string="Department"/>
                <field name="message_id"     string="Campaign"/>
                <field name="recipient_name" string="Name"/>
                <field name="phone_number"   string="Phone"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'sent'"
                       decoration-danger="status == 'failed'"
                       decoration-warning="status == 'rejected'"
                       decoration-muted="status in ['pending','draft']"/>
                <field name="cost"           string="Cost (KES)" digits="[10,4]"/>
                <field name="at_message_id"  optional="hide"/>
                <field name="failure_reason" optional="show"/>
            </list>
        </field>
    </record>

    <record id="su_sms_detail_view_search" model="ir.ui.view">
        <field name="name">su.sms.detail.search.billing</field>
        <field name="model">su.sms.detail</field>
        <field name="arch" type="xml">
            <search>
                <field name="department_id"/>
                <field name="recipient_name" string="Name"/>
                <field name="phone_number"   string="Phone"/>
                <field name="message_id"     string="Campaign"/>
                <filter name="status_sent"   string="Sent"
                        domain="[('status','=','sent')]"/>
                <filter name="status_failed" string="Failed"
                        domain="[('status','=','failed')]"/>
                <separator/>
                <filter name="this_month" string="This Month"
                        domain="[('create_date','&gt;=', datetime.datetime.now().replace(day=1, hour=0, minute=0, second=0, microsecond=0))]"/>
                <separator/>
                <filter name="by_dept"  string="Group by Department"
                        context="{'group_by': 'department_id'}"/>
                <filter name="by_month" string="Group by Month"
                        context="{'group_by': 'create_date:month'}"/>
            </search>
        </field>
    </record>

    <record id="action_su_sms_billing_report" model="ir.actions.act_window">
        <field name="name">SMS Billing Report</field>
        <field name="res_model">su.sms.detail</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_status_sent': 1, 'search_default_by_dept': 1}</field>
    </record>

    <record id="action_su_sms_dept_expenditure" model="ir.actions.act_window">
        <field name="name">Department Expenditure</field>
        <field name="res_model">su.sms.message</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_state_done': 1, 'search_default_by_dept': 1, 'search_default_by_month': 1}</field>
    </record>

</odoo>