<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         Top-level SU SMS Menu
    ============================================================ -->
    <menuitem id="menu_su_sms_root"
              name="SU SMS"
              sequence="50"
              web_icon="su_sms_integrated,static/description/icon.png"
              groups="su_sms_integrated.group_su_sms_user"/>

    <!-- Dashboard -->
    <menuitem id="menu_su_sms_dashboard"
              name="Dashboard"
              parent="menu_su_sms_root"
              action="action_su_sms_dashboard"
              sequence="1"
              groups="su_sms_integrated.group_su_sms_user"/>

    <!-- Send SMS (compose wizard) -->
    <menuitem id="menu_su_sms_compose"
              name="Send SMS"
              parent="menu_su_sms_root"
              action="action_su_sms_compose_quick"
              sequence="5"
              groups="su_sms_integrated.group_su_sms_user"/>

    <!-- SMS History -->
    <menuitem id="menu_su_sms_history"
              name="SMS History"
              parent="menu_su_sms_root"
              action="action_su_sms_message"
              sequence="10"
              groups="su_sms_integrated.group_su_sms_user"/>

    <!-- ============================================================
         Reports section (managers only)
         ADDED: these menu items were missing from the original code, 
         so I added them based on the defined actions and groups.
    ============================================================ -->
    <menuitem id="menu_su_sms_reports_root"
              name="Reports"
              parent="menu_su_sms_root"
              sequence="70"
              groups="su_sms_integrated.group_su_sms_manager"/>

    <!-- Per-recipient billing detail: pivot + graph + list
         Shows cost per department × month at the individual SMS level -->
    <menuitem id="menu_su_sms_billing_report"
              name="SMS Billing Report"
              parent="menu_su_sms_reports_root"
              action="action_su_sms_billing_report"
              sequence="1"
              groups="su_sms_integrated.group_su_sms_manager"/>

    <!-- Campaign-level roll-up: total cost per department
         Useful for month-end KFS5 reconciliation -->
    <menuitem id="menu_su_sms_dept_expenditure"
              name="Department Expenditure"
              parent="menu_su_sms_reports_root"
              action="action_su_sms_dept_expenditure"
              sequence="2"
              groups="su_sms_integrated.group_su_sms_manager"/>

    <!-- ============================================================
         Administration section (managers only)
    ============================================================ -->
    <menuitem id="menu_su_sms_admin_root"
              name="Administration"
              parent="menu_su_sms_root"
              sequence="90"
              groups="su_sms_integrated.group_su_sms_manager"/>

    <menuitem id="menu_su_sms_departments"
              name="Departments"
              parent="menu_su_sms_admin_root"
              action="action_su_sms_department"
              sequence="1"
              groups="su_sms_integrated.group_su_sms_manager"/>

    <menuitem id="menu_su_sms_administrators"
              name="Administrators"
              parent="menu_su_sms_admin_root"
              action="action_su_sms_administrator"
              sequence="2"
              groups="su_sms_integrated.group_su_sms_manager"/>
</odoo>