<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Simple notice in SMS Marketing menu -->
        <record id="view_sms_marketing_notice" model="ir.ui.view">
            <field name="name">sms.marketing.notice</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="sms.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                
                <!-- Add notice at the very top of SMS settings -->
                <xpath expr="//div[@class='app_settings_block'][@data-string='SMS Marketing']" position="inside">
                    
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"></div>
                            <div class="o_setting_right_pane">
                                <div class="alert alert-info mb-0" role="alert">
                                    <h5 class="alert-heading">🎓 Strathmore University SMS</h5>
                                    <p>
                                        Africa's Talking SMS gateway is managed through the 
                                        <strong>SU SMS System</strong> module.
                                    </p>
                                    <hr/>
                                    <p class="mb-0">
                                        <strong>Configure credentials:</strong><br/>
                                        <em>SU SMS System → Configuration → Gateway Settings</em>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </xpath>
                
            </field>
        </record>
        
    </data>
</odoo>