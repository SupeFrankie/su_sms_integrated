<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_sms" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.su.sms</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="sms.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                
                <xpath expr="//div[@data-key='sms']" position="inside">
                    
                    <block title="Strathmore SMS System" id="su_sms_settings_block">
                        <setting id="su_sms_provider_notice_setting" string="Africa's Talking Integration">
                            <div class="text-muted">
                                When "Africa's Talking" is selected, SMS will be routed through the SU SMS Gateway.
                            </div>
                            <div class="content-group mt-2">
                                <div class="alert alert-info" role="alert">
                                    <i class="fa fa-info-circle"/> 
                                    <strong> Configuration:</strong> Go to <span class="fw-bold">SU SMS System → Configuration → Gateway Settings</span>.
                                </div>
                            </div>
                        </setting>
                    </block>
                    
                </xpath>
                
            </field>
        </record>
    </data>
</odoo>