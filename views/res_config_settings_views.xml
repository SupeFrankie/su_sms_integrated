<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_sms_at" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sms.at</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block"
                     data-string="SMS - Africa's Talking"
                     data-key="su_sms_integrated"
                     groups="su_sms_integrated.group_sms_system_admin">
                    <h2>Africa's Talking Gateway</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="at_username" string="AT Username"/>
                                <div class="text-muted">
                                    Use 'sandbox' for testing
                                </div>
                                <field name="at_username" class="o_light_label"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="at_api_key" string="AT API Key"/>
                                <field name="at_api_key" password="True" 
                                       class="o_light_label"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="at_sender_id" string="Sender ID"/>
                                <div class="text-muted">
                                    Optional — leave blank to use default
                                </div>
                                <field name="at_sender_id" class="o_light_label"/>
                            </div>
                        </div>
                    </div>
                    <h2>LDAP / Active Directory</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ldap_server"/>
                                <field name="ldap_server" class="o_light_label"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ldap_port"/>
                                <field name="ldap_port" class="o_light_label"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ldap_bind_dn"/>
                                <field name="ldap_bind_dn" class="o_light_label"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ldap_bind_password"/>
                                <field name="ldap_bind_password" 
                                       password="True" class="o_light_label"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ldap_staff_base_dn"/>
                                <field name="ldap_staff_base_dn" class="o_light_label"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ldap_student_base_dn"/>
                                <field name="ldap_student_base_dn" class="o_light_label"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>