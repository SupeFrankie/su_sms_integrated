<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sms_manual_wizard_form" model="ir.ui.view">
        <field name="name">sms.manual.wizard.form</field>
        <field name="model">sms.manual.wizard</field>
        <field name="arch" type="xml">
            <form string="Manual SMS">
                <sheet>
                    <group>
                        <field name="phone_numbers" widget="text" 
                               placeholder="0712345678, 0723456789, +254734567890"/>
                        <field name="recipient_count" readonly="1"/>
                    </group>
                    <group>
                        <field name="template_id"/>
                        <field name="body" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_send_sms" string="Send SMS" 
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sms_manual_wizard" model="ir.actions.act_window">
        <field name="name">Manual SMS</field>
        <field name="res_model">sms.manual.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>