<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sms_staff_wizard_form" model="ir.ui.view">
        <field name="name">sms.staff.wizard.form</field>
        <field name="model">sms.staff.wizard</field>
        <field name="arch" type="xml">
            <form string="Staff SMS">
                <sheet>
                    <group>
                        <group string="Filters">
                            <field name="department_ids" widget="many2many_tags"/>
                            <field name="gender"/>
                            <field name="category_id"/>
                            <field name="job_status"/>
                        </group>
                        <group>
                            <field name="recipient_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="template_id"/>
                        <field name="body" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_send_sms" string="Send SMS" 
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sms_staff_wizard" model="ir.actions.act_window">
        <field name="name">Staff SMS</field>
        <field name="res_model">sms.staff.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>