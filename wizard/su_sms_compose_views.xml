<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="su_sms_compose_view_form" model="ir.ui.view">
        <field name="name">su.sms.compose.form</field>
        <field name="model">su.sms.compose</field>
        <field name="mode">primary</field>
        <field name="arch" type="xml">

            <form string="Send SMS">

                <!-- ==================================================================
                     STEP 1 - SMS Type + Sender  (always visible)
                ================================================================== -->
                <group string="1 - Select SMS Type and Sender">
                    <field name="sms_type" widget="radio"
                           options="{'horizontal': true}" required="1"/>
                    <field name="administrator_id" required="1"/>
                    <!--
                        IMPORTANT: department_name must remain a Char field (not Many2one).
                        A Many2one in a TransientModel gets serialised as a dict by Odoo 19
                        OWL and causes "TypeError: unhashable type: dict" on the second
                        onchange call. See commit history for full root-cause analysis.
                    -->
                    <field name="department_name" readonly="1"/>
                </group>

                <!-- ==================================================================
                     STEP 2 - MANUAL
                     Only phone numbers. No CSV upload
                     NOTE: invisible must be on a <div>, not on a <group>
                     with a string="" attribute. In Odoo 19 OWL, titled groups
                     cache their visibility at first render and don't re-evaluate.
                ================================================================== -->
                <div invisible="sms_type != 'manual'">
                    <group string="2 - Recipients">
                        <field name="manual_numbers"
                               widget="text"
                               nolabel="1"
                               placeholder="Enter phone numbers separated by commas or new lines&#10;+254727374660, 0712345678, ..."
                               style="min-height:100px; width:100%;"/>
                    </group>
                </div>

                <!-- ==================================================================
                     STEP 2 - AD HOC (CSV Upload)
                ================================================================== -->
                <div invisible="sms_type != 'adhoc'">
                    <group string="2 - Upload CSV">
                        <div class="alert alert-info mb-2" role="alert">
                            CSV columns: <strong>firstname</strong>,
                            <strong>lastname</strong>,
                            <strong>phone_number</strong>,
                            <strong>mobile_number</strong>.
                            Download the template below, fill it in, then upload.
                        </div>
                        <field name="csv_file" widget="binary"
                               filename="csv_filename" nolabel="1"/>
                        <field name="csv_filename" invisible="1"/>
                        <button name="action_download_csv_template"
                                string="Download Template"
                                type="object"
                                icon="fa-download"
                                class="oe_link"/>
                    </group>
                </div>

                <!-- ==================================================================
                     STEP 2 - STAFF FILTERS
                     No parent fields - this goes to staff members only.
                ================================================================== -->
                <div invisible="sms_type != 'staff'">
                    <group string="2 - Staff Filters">
                        <field name="staff_department"
                               placeholder="Leave blank for all departments"/>
                        <field name="staff_gender"/>
                        <field name="staff_category"
                               placeholder="Leave blank for all"/>
                        <field name="staff_job_status"
                               placeholder="Leave blank for all"/>
                    </group>
                </div>

                <!-- ==================================================================
                     STEP 2 - STUDENT FILTERS
                     Parents (fathers / mothers) only make sense here.
                ================================================================== -->
                <div invisible="sms_type != 'student'">
                    <group string="2 - Student Filters">
                        <field name="student_school"
                               placeholder="Leave blank for all schools"/>
                        <field name="student_program"
                               placeholder="Leave blank for all programs"/>
                        <field name="student_course"
                               placeholder="Leave blank for all courses"/>
                        <field name="student_year"
                               placeholder="e.g. 1, 2, 3, 4"/>
                        <field name="student_intake"
                               placeholder="Leave blank for all intakes"/>
                        <separator string="Recipient Groups"/>
                        <field name="include_students" widget="boolean_toggle"/>
                        <field name="include_fathers"  widget="boolean_toggle"/>
                        <field name="include_mothers"  widget="boolean_toggle"/>
                    </group>
                </div>

                <!-- ==================================================================
                     STEP 3 - Message Body  (always visible)
                ================================================================== -->
                <div class="o_wrap_field px-3 py-2">
                    <div class="o_form_label fw-bold text-uppercase text-muted small"
                         style="letter-spacing:.05em">3 - Message</div>
                    <hr class="mt-1 mb-2"/>
                    <field name="body"
                           widget="text"
                           nolabel="1"
                           placeholder="Type your SMS message here…"
                           required="1"
                           style="width:100%; min-height:140px; font-size:1rem;
                                  border-radius:6px; resize:vertical;"/>
                </div>

                <!-- ==================================================================
                     STEP 4 - Recipients Preview
                     Manual / Ad Hoc : live count + parsed table.
                     Staff / Student  : info note (fetched at send time).
                ================================================================== -->
                <div class="o_wrap_field px-3 py-2">
                    <div class="o_form_label fw-bold text-uppercase text-muted small"
                         style="letter-spacing:.05em">4 - Recipients Preview</div>
                    <hr class="mt-1 mb-2"/>

                    <!-- Live count + table (manual + adhoc) -->
                    <div invisible="sms_type not in ['manual', 'adhoc']">
                        <div class="mb-2">
                            <span class="badge bg-primary rounded-pill">
                                <field name="recipient_count" readonly="1" nolabel="1"/>
                                recipients
                            </span>
                        </div>
                        <field name="preview_html" nolabel="1" readonly="1"
                               style="width:100%"/>
                    </div>

                    <!-- Info note for staff / student -->
                    <div invisible="sms_type not in ['staff', 'student']">
                        <div class="alert alert-info mb-0" role="alert">
                            <i class="fa fa-info-circle me-1"/>
                            Recipients will be fetched from the
                            <strong>web service</strong> when you click
                            <strong>Send SMS</strong>.
                        </div>
                    </div>
                </div>

                <footer>
                    <button string="Send SMS" type="object" name="action_send"
                            class="btn-primary" icon="fa-paper-plane"
                            data-hotkey="q"/>
                    <button string="Discard" special="cancel"
                            class="btn-secondary" data-hotkey="x"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- Action to open compose wizard -->
    <record id="action_su_sms_compose" model="ir.actions.act_window">
        <field name="name">Send SMS</field>
        <field name="res_model">su.sms.compose</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>