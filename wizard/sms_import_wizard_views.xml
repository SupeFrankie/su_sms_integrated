<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sms_import_wizard_form" model="ir.ui.view">
        <field name="name">sms.import.wizard.form</field>
        <field name="model">sms.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Recipients">
                <header>
                    <button name="action_download_template" string="Download Template" 
                            type="object" class="btn-secondary" 
                            invisible="state != 'upload'"/>
                    <button name="action_parse_csv" string="Parse CSV" 
                            type="object" class="btn-primary" 
                            invisible="state != 'upload'"/>
                    <button name="action_proceed_to_compose" string="Next: Compose Message" 
                            type="object" class="btn-primary" 
                            invisible="state != 'preview'"/>
                    <button name="action_send_sms" string="Send SMS" 
                            type="object" class="btn-primary" 
                            invisible="state != 'compose'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group invisible="state != 'upload'">
                        <field name="import_file" widget="binary" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    
                    <group invisible="state != 'preview'">
                        <group>
                            <field name="valid_count" readonly="1"/>
                            <field name="invalid_count" readonly="1"/>
                        </group>
                    </group>
                    
                    <notebook invisible="state != 'preview'">
                        <page string="Imported Contacts">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom" decoration-danger="not is_valid">
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                    <field name="phone_number"/>
                                    <field name="is_valid" invisible="1"/>
                                    <field name="error_message" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    
                    <group invisible="state != 'compose'">
                        <field name="template_id"/>
                        <field name="body" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sms_import_wizard" model="ir.actions.act_window">
        <field name="name">Ad Hoc SMS</field>
        <field name="res_model">sms.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>